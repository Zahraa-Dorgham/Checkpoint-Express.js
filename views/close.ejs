<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>We Are Closed - Business Portal</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="closed-page">
    <div class="closed-container">
      <h1>🚪 We Are Currently Closed</h1>
      <p class="closed-message">
        Our office is currently closed. We operate during business hours only.
      </p>
      
      <div class="hours-info">
        <h2>Working Hours</h2>
        <p><strong>Monday - Friday:</strong> 9:00 AM - 5:00 PM</p>
        <p><strong>Weekends:</strong> Closed</p>
      </div>
      
      <p class="closed-text">
        Please come back during our working hours. If you have an urgent matter, please email us at 
        <a href="mailto:info@businessportal.com">info@businessportal.com</a>
      </p>
      
      <div class="clock">
        <p id="current-time"></p>
      </div>
    </div>
  </div>

  <script>
    function updateTime() {
      const now = new Date();
      document.getElementById('current-time').textContent = 'Current time: ' + now.toLocaleTimeString();
    }
    updateTime();
    setInterval(updateTime, 1000);
  </script>

  <style>
    body {
      margin: 0;
      padding: 0;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .closed-page {
      width: 100%;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .closed-container {
      background: white;
      border-radius: 10px;
      padding: 40px;
      max-width: 600px;
      width: 100%;
      text-align: center;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .closed-container h1 {
      font-size: 2.5em;
      color: #764ba2;
      margin-bottom: 10px;
    }

    .closed-message {
      font-size: 1.1em;
      color: #666;
      margin-bottom: 30px;
    }

    .hours-info {
      background: #f0f0f0;
      padding: 20px;
      border-radius: 8px;
      margin: 20px 0;
    }

    .hours-info h2 {
      margin-top: 0;
      color: #333;
    }

    .hours-info p {
      margin: 5px 0;
      color: #555;
    }

    .closed-text {
      color: #666;
      margin: 20px 0;
    }

    .closed-text a {
      color: #667eea;
      text-decoration: none;
      font-weight: bold;
    }

    .closed-text a:hover {
      text-decoration: underline;
    }

    .clock {
      margin-top: 30px;
      padding: 15px;
      background: #f9f9f9;
      border-radius: 8px;
    }

    #current-time {
      font-size: 1.3em;
      color: #764ba2;
      font-weight: bold;
      margin: 0;
    }
  </style>
</body>
</html>