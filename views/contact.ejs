<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us - Business Portal</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="logo">Business Portal</a>
      <ul class="nav-menu">
        <li><a href="/" class="nav-link">Home</a></li>
        <li><a href="/services" class="nav-link">Our Services</a></li>
        <li><a href="/contact" class="nav-link active">Contact Us</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <div class="page-content">
      <h1>Contact Us</h1>
      <p class="intro-text">
        Have questions or want to discuss your project? We'd love to hear from you!
      </p>
      
      <div class="contact-section">
        <div class="contact-info">
          <h2>Get In Touch</h2>
          
          <div class="info-item">
            <h3>Email</h3>
            <p><a href="mailto:info@businessportal.com">info@businessportal.com</a></p>
          </div>
          
          <div class="info-item">
            <h3>Phone</h3>
            <p><a href="tel:+1-555-123-4567">+1 (555) 123-4567</a></p>
          </div>
          
          <div class="info-item">
            <h3>Address</h3>
            <p>123 Business Street<br>Suite 100<br>New York, NY 10001<br>United States</p>
          </div>
          
          <div class="info-item">
            <h3>Hours</h3>
            <p>Monday - Friday: 9:00 AM - 5:00 PM EST<br>Weekends: Closed</p>
          </div>
        </div>

        <div class="contact-form">
          <h2>Send us a Message</h2>
          <form>
            <div class="form-group">
              <label for="name">Name:</label>
              <input type="text" id="name" name="name" required>
            </div>
            
            <div class="form-group">
              <label for="email">Email:</label>
              <input type="email" id="email" name="email" required>
            </div>
            
            <div class="form-group">
              <label for="subject">Subject:</label>
              <input type="text" id="subject" name="subject" required>
            </div>
            
            <div class="form-group">
              <label for="message">Message:</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            
            <button type="submit" class="btn">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>&copy; 2026 Business Portal. All rights reserved.</p>
    <p>Working hours: Monday - Friday, 9 AM - 5 PM</p>
  </footer>
</body>
</html>
