<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact us - Sweet Crumbs</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="inner-page">
  <header class="bakery-header">
    <button class="menu-button" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <a href="/" class="bakery-logo">
      <span class="logo-mark">BAKERY</span>
      <span class="logo-subtitle">Sweet Crumbs</span>
    </a>
    <nav class="bakery-nav">
      <a href="/">Home</a>
      <a href="/menu">Menu</a>
      <a href="/services">Our Services</a>
      <a href="/contact" class="active">Contact us</a>
    </nav>
    <a href="/contact" class="outline-button">Order Now</a>
  </header>

  <main>
    <section class="inner-hero contact-hero">
      <div>
        <p class="section-kicker">Order with us</p>
        <h1>Contact us</h1>
        <p>Tell us your date, flavor, size, and cake idea. We will help you shape it beautifully.</p>
      </div>
    </section>

    <section class="elegant-section">
      <div class="contact-section elegant-contact">
        <aside class="contact-info elegant-card">
          <p class="section-kicker">Bakery Details</p>

          <div class="info-item">
            <h3>Email</h3>
            <p><a href="mailto:orders@sweetcrumbs.com">orders@sweetcrumbs.com</a></p>
          </div>

          <div class="info-item">
            <h3>Phone</h3>
            <p><a href="tel:+21655789685">+216 55 789 685</a></p>
          </div>

          <div class="info-item">
            <h3>Address</h3>
            <p>6010 Shorfaa<br>Metouia - Gabes<br>Tunisia</p>
          </div>

          <div class="info-item">
            <h3>Hours</h3>
            <p>Monday - Friday: 9:00 AM - 5:00 PM<br>Weekends: Closed</p>
          </div>
        </aside>

        <div class="contact-form elegant-card">
          <p class="section-kicker">Message</p>
          <h2>Order Inquiry</h2>
          <form>
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="Birthday cake, wedding cake, cupcakes..." required>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us the date, cake size, flavor, and decoration idea." required></textarea>
            </div>

            <button type="submit" class="btn dark-btn">Send Inquiry</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <a href="/" class="footer-logo">Sweet Crumbs</a>
    <p>Fresh cakes, pastries, and dessert tables for elegant celebrations.</p>
    <div class="social-links">
      <a href="#" aria-label="Instagram">
        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1"></circle></svg>
      </a>
      <a href="#" aria-label="Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8h3V4h-3c-3 0-5 2-5 5v3H6v4h3v5h4v-5h3l1-4h-4V9c0-.6.4-1 1-1z"></path></svg>
      </a>
      <a href="#" aria-label="Snapchat">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3c3 0 5 2.4 5 5.6v2.1c0 1.4 1.3 2.2 2.6 2.6-.6 1.5-2 2.3-3.6 2.5-.7 1.5-2 2.2-4 2.2s-3.3-.7-4-2.2c-1.6-.2-3-.9-3.6-2.5 1.3-.4 2.6-1.2 2.6-2.6V8.6C7 5.4 9 3 12 3z"></path></svg>
      </a>
    </div>
    <small>&copy; 2026 Sweet Crumbs Cake Bakery. Monday - Friday, 9 AM - 5 PM.</small>
  </footer>
</body>
</html>
